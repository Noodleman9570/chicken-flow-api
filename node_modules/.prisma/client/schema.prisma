// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// MÓDULO 12: USUARIOS Y ROLES
// ============================
enum UserRole {
  admin
  operator
  client
  develop
}

enum UserStatus {
  activo
  pendiente
  bloqueado
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(operator)
  status       UserStatus @default(pendiente)
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relaciones
  assignedFarms FarmUser[]
  createdLots   Lot[]         @relation("LotCreator")
  dailyRecords  DailyRecord[]
  reports       Report[]

  @@map("users")
}

// ============================
// MÓDULO 02: GRANJAS E INFRAESTRUCTURA
// ============================
enum FarmStatus {
  activa
  mantenimiento
  inactiva
}

model Farm {
  id              String     @id @default(cuid())
  name            String
  location        String
  areaM2          Float      @map("area_m2")
  zones           Int
  capacity        Int
  status          FarmStatus @default(activa)
  nextMaintenance DateTime?  @map("next_maintenance")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relaciones
  users         FarmUser[]
  lots          Lot[]
  feedInventory FeedInventory[]

  @@map("farms")
}

model FarmUser {
  farmId        String  @map("farm_id")
  userId        String  @map("user_id")
  isResponsible Boolean @default(false) @map("is_responsible")

  farm User @relation(fields: [userId], references: [id])
  user Farm @relation(fields: [farmId], references: [id])

  @@id([farmId, userId])
  @@map("farm_users")
}

// ============================
// MÓDULOS 03 y 04: LOTES (PILOTO Y ESCALONADOS)
// ============================
enum LotStatus {
  programado
  activo
  en_revision
  finalizado
  cancelado
}

enum FeedType {
  iniciador
  finalizador
  mixto
  preiniciador
}

enum RiskLevel {
  bajo
  medio
  alto
}

model Lot {
  id                  String    @id @default(cuid())
  code                String    @unique // L-YYYY-NNN
  farmId              String    @map("farm_id")
  zone                String?
  birdsInitial        Int       @map("birds_initial")
  birdsAlive          Int       @map("birds_alive")
  durationDays        Int       @default(42) @map("duration_days")
  startDate           DateTime  @map("start_date")
  expectedHarvestDate DateTime  @map("expected_harvest_date")
  status              LotStatus @default(programado)
  riskLevel           RiskLevel @default(bajo) @map("risk_level")

  // Precios e inversión inicial
  pricePollito      Float @map("price_pollito")
  priceIniciador    Float @map("price_iniciador") // Precio por bulto 40kg
  priceFinalizador  Float @map("price_finalizador") // Precio por bulto 40kg
  priceViruta       Float @map("price_viruta")
  priceVacunas      Float @map("price_vacunas")
  costCalefaccion   Float @map("cost_calefaccion")
  costTransporte    Float @map("cost_transporte")
  costProcesamiento Float @map("cost_procesamiento")
  costEntrega       Float @map("cost_entrega")
  priceSaleLb       Float @map("price_sale_lb") // Precio de venta por libra

  // Metas esperadas
  expectedWeightKg    Float?  @map("expected_weight_kg")
  expectedCarcassKg   Float?  @map("expected_carcass_kg") // Peso canal
  observationsInitial String? @map("observations_initial") @db.Text

  // Auditoría
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relaciones
  farm          Farm           @relation(fields: [farmId], references: [id])
  creator       User           @relation("LotCreator", fields: [createdBy], references: [id])
  dailyRecords  DailyRecord[]
  weeklyRecords WeeklyRecord[]
  invoices      Invoice[]

  @@map("lots")
}

// ============================
// MÓDULOS 03 y 05: REGISTROS DIARIOS
// ============================
model DailyRecord {
  id                   String   @id @default(cuid())
  lotId                String   @map("lot_id")
  cyclDay              Int      @map("cycle_day")
  date                 DateTime @db.Date
  birdsAliveStart      Int      @map("birds_alive_start")
  deadBirds            Int      @default(0) @map("dead_birds")
  deathCause           String?  @map("death_cause")
  feedKg               Float    @map("feed_kg")
  feedType             FeedType @map("feed_type")
  waterChanged         Boolean  @default(true) @map("water_changed")
  temperatureMorning   Float?   @map("temperature_morning")
  temperatureAfternoon Float?   @map("temperature_afternoon")
  observations         String?  @db.Text
  operatorId           String?  @map("operator_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  lot      Lot   @relation(fields: [lotId], references: [id])
  operator User? @relation(fields: [operatorId], references: [id])

  @@unique([lotId, cyclDay])
  @@map("daily_records")
}

// ============================
// MÓDULO 03: REGISTROS SEMANALES (PESAJES)
// ============================
model WeeklyRecord {
  id             String   @id @default(cuid())
  lotId          String   @map("lot_id")
  weekNumber     Int      @map("week_number")
  startDay       Int      @map("start_day")
  endDay         Int      @map("end_day")
  weighingDate   DateTime @map("weighing_date") @db.Date
  bird1WeightG   Float    @map("bird_1_weight_g")
  bird2WeightG   Float    @map("bird_2_weight_g")
  bird3WeightG   Float    @map("bird_3_weight_g")
  bird4WeightG   Float    @map("bird_4_weight_g")
  bird5WeightG   Float    @map("bird_5_weight_g")
  avgWeightG     Float?   @map("avg_weight_g") // Calculado automáticamente
  feedConsumedKg Float    @map("feed_consumed_kg")
  deadBirdsWeek  Int      @default(0) @map("dead_birds_week")
  observations   String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  lot Lot @relation(fields: [lotId], references: [id])

  @@unique([lotId, weekNumber])
  @@map("weekly_records")
}

// ============================
// MÓDULO 06: INVENTARIO DE ALIMENTO
// ============================
enum InventoryStatus {
  suficiente
  bajo
  critico
}

model FeedInventory {
  id              String          @id @default(cuid())
  farmId          String          @map("farm_id")
  feedType        FeedType        @map("feed_type")
  brand           String
  stockKg         Float           @map("stock_kg")
  reservedKg      Float           @default(0) @map("reserved_kg")
  unitCost        Float           @map("unit_cost")
  storageLocation String?         @map("storage_location")
  expirationDate  DateTime?       @map("expiration_date") @db.Date
  status          InventoryStatus @default(suficiente)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  farm      Farm           @relation(fields: [farmId], references: [id])
  purchases FeedPurchase[]

  @@map("feed_inventory")
}

model FeedPurchase {
  id           String   @id @default(cuid())
  inventoryId  String   @map("inventory_id")
  quantityKg   Float    @map("quantity_kg")
  unitCost     Float    @map("unit_cost")
  totalCost    Float    @map("total_cost")
  purchaseDate DateTime @map("purchase_date") @db.Date
  supplier     String?
  invoiceRef   String?  @map("invoice_ref")
  createdAt    DateTime @default(now()) @map("created_at")

  inventory FeedInventory @relation(fields: [inventoryId], references: [id])

  @@map("feed_purchases")
}

// ============================
// MÓDULO 07: CLIENTES
// ============================
enum CustomerType {
  restaurante
  distribuidor
  vecino
  asadero
  minorista
}

enum CustomerReliability {
  alta
  media
  baja
}

enum CustomerStatus {
  activo
  observacion
  inactivo
}

model Customer {
  id               String              @id @default(cuid())
  name             String
  document         String?             @unique
  phone            String?
  email            String?
  city             String?
  customerType     CustomerType        @map("customer_type")
  creditLimit      Float               @default(0) @map("credit_limit")
  balanceDue       Float               @default(0) @map("balance_due")
  reliability      CustomerReliability @default(media)
  status           CustomerStatus      @default(activo)
  lastPurchaseDate DateTime?           @map("last_purchase_date") @db.Date
  notes            String?             @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  invoices Invoice[]

  @@map("customers")
}

// ============================
// MÓDULO 08: VENTAS Y FACTURAS
// ============================
enum InvoiceStatus {
  borrador
  emitida
  pagada
  vencida
  anulada
}

enum PaymentCondition {
  contado
  credito_8_dias
  credito_15_dias
  credito_30_dias
}

model Invoice {
  id               String           @id @default(cuid())
  number           String           @unique
  customerId       String           @map("customer_id")
  lotId            String?          @map("lot_id")
  issueDate        DateTime         @map("issue_date") @db.Date
  dueDate          DateTime?        @map("due_date") @db.Date
  chickensSold     Int              @map("chickens_sold")
  totalWeightLb    Float            @map("total_weight_lb")
  pricePerLb       Float            @map("price_per_lb")
  subtotal         Float
  paidAmount       Float            @default(0) @map("paid_amount")
  status           InvoiceStatus    @default(borrador)
  paymentCondition PaymentCondition @default(contado) @map("payment_condition")
  notes            String?          @db.Text
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  customer Customer  @relation(fields: [customerId], references: [id])
  lot      Lot?      @relation(fields: [lotId], references: [id])
  payments Payment[]

  @@map("invoices")
}

// ============================
// MÓDULO 09: PAGOS Y COBROS
// ============================
enum PaymentMethod {
  efectivo
  transferencia
  nequi
  daviplata
  credito
}

enum PaymentStatus {
  pendiente
  abonado
  pagado
  vencido
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String        @map("invoice_id")
  amount        Float
  paymentMethod PaymentMethod @map("payment_method")
  paymentDate   DateTime      @map("payment_date") @db.Date
  reference     String?
  collectorId   String?       @map("collector_id")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

// ============================
// MÓDULO 10: FINANZAS Y UTILIDADES
// ============================
model FinancialDistribution {
  id                  String   @id @default(cuid())
  period              String // "2026-06"
  grossIncome         Float    @map("gross_income")
  operatingCosts      Float    @map("operating_costs")
  salariesAndServices Float    @map("salaries_and_services")
  netProfit           Float    @map("net_profit")
  reinvestmentPct     Float    @map("reinvestment_pct")
  emergencyFundPct    Float    @map("emergency_fund_pct")
  dividendsPct        Float    @map("dividends_pct")
  founderSharePct     Float    @map("founder_share_pct")
  operatorSharePct    Float    @map("operator_share_pct")
  reinvestmentAmount  Float    @map("reinvestment_amount")
  emergencyFundAmount Float    @map("emergency_fund_amount")
  dividendsAmount     Float    @map("dividends_amount")
  founderShareAmount  Float    @map("founder_share_amount")
  operatorShareAmount Float    @map("operator_share_amount")
  margin              Float
  includedLots        String[] @map("included_lots")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([period])
  @@map("financial_distributions")
}

// ============================
// MÓDULO 11: REPORTES
// ============================
enum ReportCategory {
  operativo
  financiero
  clientes
  produccion
}

enum ReportStatus {
  listo
  programado
  pendiente
}

enum ReportFormat {
  pdf
  excel
  dashboard
}

model Report {
  id          String         @id @default(cuid())
  name        String
  category    ReportCategory
  period      String
  status      ReportStatus   @default(pendiente)
  format      ReportFormat   @default(pdf)
  ownerId     String         @map("owner_id")
  filePath    String?        @map("file_path")
  filters     Json?
  generatedAt DateTime?      @map("generated_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@map("reports")
}
