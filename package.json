{
  "name": "chicken-flow-api",
  "version": "1.0.0",
  "description": "API Backend del sistema avícola Chicken Flow",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && ts-node prisma/seed.ts",
    "test": "echo \"Tests pendientes - ver requests.http para pruebas manuales\""
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "avicola",
    "api",
    "express",
    "typescript",
    "prisma"
  ],
  "author": "Chicken Flow",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.21.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "nodemon": "^3.1.14",
    "prisma": "^5.21.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@prisma/engines@5.21.1": true,
    "prisma@5.21.1": true
  }
}
