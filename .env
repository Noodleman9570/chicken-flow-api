# Variables de entorno - Chicken Flow API

# Puerto del servidor
PORT=3001

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chicken_flow?schema=public"

# JWT Secret (usar una clave fuerte en producción)
JWT_SECRET="chicken-flow-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Entorno
NODE_ENV=development

# CORS - Origen permitido (URL del frontend)
CLIENT_ORIGIN=http://localhost:3000

# Bcrypt Salt Rounds
BCRYPT_ROUNDS=10
